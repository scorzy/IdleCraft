{
  "name": "idle-craft",
  "version": "0.0.0",
  "private": true,
  "homepage": "https://scorzy.github.io/IdleCraft/",
  "type": "module",
  "scripts": {
    "dev": "vite --open",
    "host": "vite --host",
    "preview": "vite preview --open",
    "build": "tsc && vite build",
    "analyze": "vite-bundle-visualizer -c vite.config.ts",
    "lint": "oxlint src --fix and oxfmt src",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "coverage": "vitest run --coverage",
    "deploy": "gh-pages -d dist"
  },
